# Application
APP_NAME=OpenMeets
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://openmeet:openmeet_password@db:5432/openmeet
POSTGRES_PASSWORD=openmeet_password

# JWT
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (SMTP) - optional
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=user
# SMTP_PASSWORD=password
# FROM_EMAIL=noreply@example.com
# FROM_NAME=OpenMeets

# SendGrid API - optional, overrides SMTP
# SENDGRID_API_KEY=

# AWS SES - optional, overrides SMTP
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
