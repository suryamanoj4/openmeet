# Database
POSTGRES_USER=openmeet
POSTGRES_PASSWORD=openmeet_password
POSTGRES_DB=openmeet

# Backend
BACKEND_PORT=8000
DATABASE_URL=postgresql+asyncpg://openmeet:openmeet_password@db:5432/openmeet

# Frontend (dev: localhost:8000, prod: /graphql or https://yourdomain.com/graphql)
FRONTEND_PORT=5173
PUBLIC_GRAPHQL_URL=http://localhost:8000/graphql

# Nginx (production only)
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Razorpay (payment provider)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxx

# JWT
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (SMTP) - optional
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=user
# SMTP_PASSWORD=password
# FROM_EMAIL=noreply@example.com
# FROM_NAME=OpenMeets

# SendGrid API - optional, overrides SMTP
# SENDGRID_API_KEY=

# AWS SES - optional, overrides SMTP
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
