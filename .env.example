# Application
APP_NAME=OpenMeets
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://openmeet:openmeet_password@localhost:5432/openmeet

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=
FROM_NAME=OpenMeets

# SendGrid API (optional, overrides SMTP)
SENDGRID_API_KEY=

# AWS SES (optional, overrides SMTP)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
